generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// Auth Models
//////////////////////////////////////////////////////

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  phone         String?
  role          Role           @default(CUSTOMER)
  emailVerified Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  image         String?
  pageProgress  PageProgress[]
  location      String?
  device        String?
  isOnline      Boolean        @default(false)
  lastSeen      DateTime?

  assignedBooks AssignedBook[]

  accounts          Account[]
  sessions          Session[]
  matchmakingQueues MatchmakingQueue[]
  // Chess relations
  gamesAsWhite      Game[]             @relation("whitePlayer")
  gamesAsBlack      Game[]             @relation("blackPlayer")
  moves             Move[]
  statistics        UserStatistics?
  loginActivities   LoginActivity[]

  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  @@map("user")
}

model MatchmakingQueue {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  gameType    String @default("CHESS")
  timeControl String @default("10+0")

  createdAt DateTime @default(now())

  @@unique([userId, gameType])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@index([userId])
  @@map("session")
}

model Account {
  id         String @id @default(cuid())
  accountId  String
  providerId String
  userId     String

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?

  password String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum Role {
  ADMIN
  EMPLOYEE
  CUSTOMER
}

//////////////////////////////////////////////////////
// Academic CMS Models
//////////////////////////////////////////////////////

model Level {
  id   String @id @default(cuid())
  name String
  slug String @unique

  classes Class[]
}

model Class {
  id   String @id @default(cuid())
  name String
  slug String

  levelId String
  isGame  Boolean @default(false)
  level   Level   @relation(fields: [levelId], references: [id])

  subjects Subject[]

  @@unique([slug, levelId])
}

model Subject {
  id   String @id @default(cuid())
  name String
  slug String

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  publications Publication[]

  @@unique([slug, classId])
}

model Publication {
  id String @id @default(cuid())

  title String
  slug  String @unique

  description String

  href String

  author String?

  coverImage String?

  totalPages Int @default(0)

  assignedTo AssignedBook[]

  subjectId String

  subject Subject @relation(fields: [subjectId], references: [id])

  pages PublicationPage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PublicationPage {
  id String @id @default(cuid())

  publicationId String

  publication Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  pageNumber Int

  title String?

  // Main A4 image
  imageUrl String

  // HD zoom image
  hdImageUrl String?

  // Grid thumbnail
  thumbnailUrl String?

  // OCR / searchable text
  contentText String? @db.Text

  width Int?

  height Int?

  backgroundColor String?

  template String?

  isPublished Boolean @default(true)

  pageProgress PageProgress[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([publicationId, pageNumber])
  @@index([publicationId])
  @@index([isPublished])
}

model AssignedBook {
  id            String      @id @default(cuid())
  employeeId    String
  publicationId String
  status        String      @default("IN_PROGRESS")
  employee      User        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([employeeId, publicationId])
  @@index([employeeId])
  @@index([publicationId])
}

model PageProgress {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  pageId String
  page   PublicationPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  completed Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([userId, pageId])
  @@index([userId])
  @@index([pageId])
}

//////////////////////////////////////////////////////
// Chess Game Models
//////////////////////////////////////////////////////

model Game {
  id            String   @id @default(cuid())
  gameType      GameType @default(CHESS)
  // Players
  whitePlayerId String
  blackPlayerId String

  whitePlayer User @relation("whitePlayer", fields: [whitePlayerId], references: [id], onDelete: Cascade)
  blackPlayer User @relation("blackPlayer", fields: [blackPlayerId], references: [id], onDelete: Cascade)

  // Game State
  position     String      @default("rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1") @db.Text
  status       GameStatus  @default(ACTIVE)
  result       GameResult?
  resultReason String?

  // Timing
  timeControl        String @default("10+0")
  whiteTimeRemaining Int?
  blackTimeRemaining Int?

  // Metadata
  moves       Move[]
  moveCount   Int    @default(0)
  currentTurn Turn   @default(WHITE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  startedAt DateTime?
  endedAt   DateTime?

  // Ratings
  whiteRatingBefore Int?
  whiteRatingAfter  Int?
  blackRatingBefore Int?
  blackRatingAfter  Int?

  @@index([whitePlayerId])
  @@index([blackPlayerId])
  @@index([status])
  @@index([createdAt])
  @@map("game")
}

model Move {
  id String @id @default(cuid())

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  moveNumber Int
  ply        Int

  from      String
  to        String
  san       String?
  promotion String?

  capture   Boolean @default(false)
  check     Boolean @default(false)
  checkmate Boolean @default(false)
  castling  String?
  enPassant Boolean @default(false)

  playerId String
  player   User   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  notation String?

  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([gameId])
  @@index([playerId])
  @@index([timestamp])
  @@map("move")
}

model UserStatistics {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ratingBlitz     Int @default(1200)
  ratingRapid     Int @default(1200)
  ratingClassical Int @default(1200)

  totalGames Int @default(0)
  wins       Int @default(0)
  losses     Int @default(0)
  draws      Int @default(0)

  winPercentage Float @default(0)

  winStreak  Int @default(0)
  lossStreak Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_statistics")
}

model ChessAchievement {
  id          String  @id @default(cuid())
  title       String
  description String  @db.Text
  badge       String?

  createdAt DateTime @default(now())

  @@map("chess_achievement")
}

model LoginActivity {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId String?
  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
}

//////////////////////////////////////////////////////
// Enums
//////////////////////////////////////////////////////

enum GameStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  DRAW_OFFERED
  DRAW_DECLINED
}

enum GameResult {
  WHITE_WIN
  BLACK_WIN
  DRAW
  ABANDONED
}

enum Turn {
  WHITE
  BLACK
}

enum GameType {
  CHESS
  TICTACTOE
  LUDO
  BAGCHAL
}

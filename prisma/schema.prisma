generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// Auth Models
//////////////////////////////////////////////////////

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  phone         String?
  role          Role      @default(CUSTOMER)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  image         String?
  assignedBooks AssignedBook[]
   location      String?
  device        String?
  isOnline      Boolean   @default(false)
  lastSeen      DateTime?

  accounts      Account[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?

  password String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum Role {
  ADMIN
  EMPLOYEE
  CUSTOMER
}

//////////////////////////////////////////////////////
// Academic CMS Models
//////////////////////////////////////////////////////

model Level {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique

  classes Class[]
}

model Class {
  id      String @id @default(cuid())
  name    String
  slug    String

  levelId String
  isGame  Boolean @default(false)
  level   Level  @relation(fields: [levelId], references: [id])

  subjects Subject[]

  @@unique([slug, levelId])
}

model Subject {
  id      String @id @default(cuid())
  name    String
  slug    String

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  publications Publication[]

  @@unique([slug, classId])
}

model Publication {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  href        String
  author      String?  // optional author for flipbook
  assignedTo  AssignedBook[]

  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])

  pages       PublicationPage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PublicationPage {
  id            String @id @default(cuid())
  pageNumber    Int
  title         String?
  content       String  @db.Text

  publicationId String
  publication   Publication @relation(fields: [publicationId], references: [id])

  createdAt     DateTime @default(now())

  @@unique([publicationId, pageNumber])
}
model AssignedBook {
  id            String   @id @default(cuid())

  employeeId    String
  publicationId String

  employee      User        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@unique([employeeId, publicationId])
}